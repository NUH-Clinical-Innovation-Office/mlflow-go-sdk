# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=10s
# Comma-separated CIDRs of trusted reverse proxies. X-Forwarded-For is
# only honored when r.RemoteAddr matches one of these. Leave empty in dev.
TRUSTED_PROXIES=

# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/go_backend_template?sslmode=disable
# Pool sizes (pgxpool naming). 25/2 are sane dev defaults; raise MaxConns in prod.
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=2
DATABASE_CONN_MAX_LIFETIME=5m

# JWT Configuration
# Must be at least 32 bytes. Generate one with: openssl rand -base64 48
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE_MINUTES=1440
BCRYPT_COST=12

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=console

# OpenTelemetry Configuration
TRACING_ENABLED=true
SERVICE_NAME=go-backend-template
SERVICE_VERSION=1.0.0
ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACE_SAMPLING_RATIO=1.0
OTEL_EXPORTER_OTLP_INSECURE=true

# Rate Limit Configuration (for future use)
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_DURATION=1m

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Swagger (set to true in development only)
SWAGGER_ENABLED=false
